# Copy to .env and fill in. Never commit .env with real secrets.

# Credentials and URLs default to the same behavior as Autobots `cbc_reader_bot.js`
# (CBC_LOGIN_USERNAME / CBC_LOGIN_PASSWORD, primary + backup login URLs).
# Optional overrides for this app only:
# LIS_LOGIN_URL=
# LIS_LOGIN_URL_BACKUP=
# LIS_LOGIN_USERNAME=
# LIS_LOGIN_PASSWORD=

# Same env names as CBC bot (optional if you use the CBC defaults baked into lisNav.js)
# CBC_LOGIN_USERNAME=
# CBC_LOGIN_PASSWORD=
# CBC_LOGIN_URL=
# CBC_LOGIN_URL_BACKUP=

# Optional: bundled or system Chromium (Puppeteer downloads its own if unset)
# CHROMIUM_EXECUTABLE_PATH=
# PUPPETEER_EXECUTABLE_PATH=

# API port (default 3001)
# PORT=3001

# Lab calendar "today" default when the UI does not send a date (IANA timezone)
TZ=Asia/Kolkata

# After each Search: wait for worksheet POST + grid/pager quiescence (large ranges / slow LIS)
# GENOMICS_POST_WAIT_MS=120000
# GENOMICS_GRID_WAIT_MS=480000
# Consecutive identical fingerprints (incl. pager max + pager strip) before accepting
# GENOMICS_GRID_STABLE_POLLS=7
# Min ms with no fingerprint change before accepting (pager often updates after rows)
# GENOMICS_GRID_MIN_STILL_MS=6000

# Default for Autobots-compatible low-memory Chromium tuning (optional)
# GENOMICS_LOW_MEMORY=0

# Production: serve built UI from Express
# NODE_ENV=production
