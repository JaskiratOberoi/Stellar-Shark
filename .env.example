# Server
PORT=3101
# Bind address (empty = all interfaces in Docker; use 127.0.0.1 for local-only)
# NEXUS_BIND=0.0.0.0

# PostgreSQL (required in Docker; optional locally — without it, JSON files under ./data are used)
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# JWT signing secret (required when DATABASE_URL is set — enables login)
# JWT_SECRET=change-me-in-production

# CORS: comma-separated allowed origins for SPA dev (e.g. Vite on :5173 calling API on :3101).
# If the UI is served from the same host as the API (Docker or reverse proxy), you often do not need this.
# Example: CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173 (Vite → API on :3101)
# Production with a separate frontend origin: CORS_ORIGINS=https://lab.example.com

# Timezone for scheduler cron (e.g. Asia/Kolkata)
TZ=Asia/Kolkata

# Force scraper to read BU labels from this folder (must contain businessUnits.json)
# NEXUS_CONFIG_DIR=/path/to/Stellar-Shark/config

# Max wall-clock time for one Teller / LIS scrape (ms). Prevents hung Puppeteer runs. Default 5400000 (90 min).
# GENOMICS_RUN_MAX_MS=5400000

# Max queued scheduler ticks waiting behind an in-flight run (default 10).
# NEXUS_SCHEDULER_QUEUE_MAX=10

# LIS / scraper (set real values in production)
# LISTEC_*

# Chromium in Docker (set by Dockerfile; override if needed)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
