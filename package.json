{
  "name": "genomics-dashboard",
  "private": true,
  "version": "1.1.1",
  "description": "Genomics LIS daily test-count dashboard (QUGEN)",
  "author": "QUGEN",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "counter": "concurrently -k -n server,web -c cyan,magenta \"npm run dev:server\" \"wait-on http-get://127.0.0.1:3001/api/health && npm run dev --prefix web\"",
    "dev:server": "node server/index.js",
    "dev:web": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "scrape": "node scraper/genomicsStatsScraper.js",
    "discover-badges": "node scripts/discoverLabBadges.js",
    "desktop:dev": "npm run build && electron .",
    "icon:prepare": "node scripts/prep-icon.js",
    "desktop:dist": "npm run icon:prepare && npm run build && electron-builder --win"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^21.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.qugen.stellar-shark",
    "productName": "Stellar Shark",
    "copyright": "Copyright © QUGEN",
    "asar": false,
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!.env",
      "!**/.env",
      "!web/src/**",
      "!web/node_modules/**",
      "!web/vite.config.js",
      "!web/tailwind.config.js",
      "!web/postcss.config.js",
      "!release/**",
      "!**/.git/**",
      "!**/.cursor/**",
      "!**/*.md",
      "!**/AGENTS.md",
      "!**/CLAUDE.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stellar Shark",
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033"
    }
  }
}
