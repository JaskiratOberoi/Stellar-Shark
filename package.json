{
  "name": "genomics-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "Genomics LIS daily test-count dashboard (QUGEN)",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "counter": "concurrently -k -n server,web -c cyan,magenta \"npm run dev:server\" \"wait-on http-get://127.0.0.1:3001/api/health && npm run dev --prefix web\"",
    "dev:server": "node server/index.js",
    "dev:web": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "start": "NODE_ENV=production node server/index.js",
    "scrape": "node scraper/genomicsStatsScraper.js",
    "discover-badges": "node scripts/discoverLabBadges.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "puppeteer": "^21.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  }
}
